generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ServiceState {
  draft
  checkout_started
  payment_pending
  paid
  provisioning_queued
  provisioning_running
  intake_required
  ai_processing
  waiting_for_client
  waiting_for_takatak
  active
  failed
  cancelled
  completed
}

enum JobStatus {
  queued
  running
  succeeded
  failed
  cancelled
}

model ServiceInstance {
  id                String       @id @default(cuid())
  userId            String
  serviceKey        String
  state             ServiceState @default(draft)
  upmindOrderId     String?
  upmindServiceId   String?
  externalPortalUrl String?
  intakeId          String?
  meta              Json         @default("{}")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  timeline AutomationTimelineEvent[]
  jobs     AutomationJob[]
  orders   Order[]
  intakes  AIIntake[]

  @@index([userId])
  @@index([userId, serviceKey])
  @@index([serviceKey])
  @@index([state])
}

model AutomationTimelineEvent {
  id                String          @id @default(cuid())
  serviceInstanceId String
  state             ServiceState
  label             String?
  message           String?
  actor             String          @default("system") // system | client | takatak
  at                DateTime        @default(now())
  service           ServiceInstance @relation(fields: [serviceInstanceId], references: [id], onDelete: Cascade)

  @@index([serviceInstanceId, at])
}

model AutomationJob {
  id                String           @id @default(cuid())
  serviceInstanceId String?
  kind              String
  status            JobStatus        @default(queued)
  attempts          Int              @default(0)
  payload           Json             @default("{}")
  lastError         String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  service           ServiceInstance? @relation(fields: [serviceInstanceId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([serviceInstanceId])
  @@index([kind])
  @@index([kind, status])
  @@index([updatedAt])
}

model AIIntake {
  id                String           @id @default(cuid())
  userId            String
  serviceKey        String
  serviceInstanceId String?
  answers           Json             @default("{}")
  brief             String?
  createdAt         DateTime         @default(now())
  service           ServiceInstance? @relation(fields: [serviceInstanceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([serviceInstanceId])
}

model ExternalIntegration {
  id          String   @id @default(cuid())
  serviceKey  String   @unique
  baseUrl     String
  config      Json     @default("{}")
  updatedAt   DateTime @updatedAt
}

model Order {
  id                String           @id @default(cuid())
  userId            String
  serviceInstanceId String?
  serviceKey        String
  upmindOrderId     String?
  status            String           @default("created") // created|paid|failed|cancelled
  amountCents       Int?
  currency          String           @default("CAD")
  meta              Json             @default("{}")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  service           ServiceInstance? @relation(fields: [serviceInstanceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([upmindOrderId])
  @@index([serviceInstanceId])
}

model MarketplaceGig {
  id          String   @id @default(cuid())
  title       String
  category    String
  description String
  priceCents  Int
  currency    String   @default("CAD")
  freelancerId String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([category])
}

model MarketplaceProject {
  id           String   @id @default(cuid())
  userId       String
  title        String
  brief        String
  budgetCents  Int?
  category     String
  status       String   @default("open")
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([category])
}

model FreelancerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  displayName String
  bio       String?
  skills    String[] @default([])
  rating    Float?
  createdAt DateTime @default(now())
}

model WebhookEvent {
  id         String   @id              // external event id from Upmind/automation
  source     String                    // "upmind" | "automation"
  receivedAt DateTime @default(now())

  @@index([receivedAt])
  @@index([source, receivedAt])
}

// =====================================================================
// Marketplace v2 — projects, freelancers, contracts, escrow
// =====================================================================

enum PaymentReleaseState {
  unpaid
  paid_to_takatak
  assigned
  accepted_by_freelancer
  in_progress
  submitted
  revision_requested
  approved
  grace_period
  release_ready
  released
  disputed
  cancelled
  refunded
}

model MarketplaceCategory {
  slug      String   @id
  name      String
  createdAt DateTime @default(now())
}

model MarketplacePackage {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  category     String
  description  String
  shortDescription String?
  longDescription  String?
  priceCents   Int
  currency     String   @default("CAD")
  deliveryDays    Int?
  deliveryEstimate String?
  serviceKey   String?
  requiresIntake  Boolean  @default(false)
  allowsQuote     Boolean  @default(true)
  status       String   @default("active") // active|draft|archived
  tags         String[] @default([])
  tiers        Json?
  addOns       Json?
  deliverables Json?
  faq          Json?
  metadata     Json?
  freelancerId String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([slug])
  @@index([category])
  @@index([freelancerId])
  @@index([status])
  @@index([active])
  @@index([serviceKey])
}

model ClientProject {
  id            String              @id @default(cuid())
  userId        String
  title         String
  brief         String
  category      String
  budgetCents   Int?
  status        String              @default("submitted")
  paymentState  PaymentReleaseState @default(unpaid)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  files       ProjectFile[]
  messages    ProjectMessage[]
  milestones  ProjectMilestone[]
  deliveries  ProjectDelivery[]
  contracts   FreelancerContract[]
  audits      ProjectAuditLog[]

  @@index([userId])
  @@index([category])
  @@index([status])
  @@index([paymentState])
}

model ProjectFile {
  id        String   @id @default(cuid())
  projectId String
  name      String
  url       String
  size      Int?
  uploadedBy String
  uploadedAt DateTime @default(now())
  project   ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectMessage {
  id        String   @id @default(cuid())
  projectId String
  fromUser  String
  body      String
  at        DateTime @default(now())
  project   ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, at])
}

model ProjectMilestone {
  id         String  @id @default(cuid())
  projectId  String
  title      String
  status     String  @default("pending") // pending|in_progress|completed
  amountCents Int?
  position   Int     @default(0)
  project    ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectDelivery {
  id         String   @id @default(cuid())
  projectId  String
  note       String?
  submittedAt DateTime @default(now())
  project    ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model FreelancerApplication {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String
  bio         String?
  skills      String[] @default([])
  status      String   @default("pending") // pending|approved|rejected
  createdAt   DateTime @default(now())
}

model FreelancerContract {
  id            String              @id @default(cuid())
  projectId     String
  freelancerId  String
  status        String              @default("assigned") // assigned|accepted|declined|in_progress|submitted|completed
  paymentState  PaymentReleaseState @default(paid_to_takatak)
  amountCents   Int
  currency      String              @default("CAD")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  project       ClientProject       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignments   ContractAssignment[]
  holds         PayoutHold[]
  releases      PayoutRelease[]
  disputes      DisputeCase[]

  @@index([freelancerId])
  @@index([projectId])
  @@index([status])
}

model ContractAssignment {
  id          String   @id @default(cuid())
  contractId  String
  assignedBy  String   // admin user id
  assignedAt  DateTime @default(now())
  note        String?
  contract    FreelancerContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
}

model PayoutHold {
  id           String   @id @default(cuid())
  contractId   String
  amountCents  Int
  currency     String   @default("CAD")
  holdUntil    DateTime
  createdAt    DateTime @default(now())
  contract     FreelancerContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
}

model PayoutRelease {
  id           String   @id @default(cuid())
  contractId   String
  amountCents  Int
  currency     String   @default("CAD")
  releasedAt   DateTime @default(now())
  reference    String?
  contract     FreelancerContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
}

model DisputeCase {
  id          String   @id @default(cuid())
  contractId  String
  openedBy    String
  reason      String
  status      String   @default("open") // open|reviewing|resolved|rejected
  resolution  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  contract    FreelancerContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([status])
}

model ProjectAuditLog {
  id         String   @id @default(cuid())
  projectId  String
  actor      String
  action     String
  data       Json     @default("{}")
  at         DateTime @default(now())
  project    ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, at])
}

// =====================================================================
// Notifications
// =====================================================================

model Notification {
  id         String   @id @default(cuid())
  userId     String
  type       String
  title      String
  message    String
  actionUrl  String?
  readAt     DateTime?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}
