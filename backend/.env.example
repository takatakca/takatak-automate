# Database
DATABASE_URL=postgresql://user:pass@host:5432/takatak

# Auth (verify JWTs minted by existing TAKATAK auth service)
AUTH_JWT_SECRET=replace-me
# OR (preferred): JWKS endpoint of your auth provider
AUTH_JWKS_URL=

# Webhook secrets (HMAC-SHA256)
UPMIND_WEBHOOK_SECRET=
AUTOMATION_WEBHOOK_SECRET=

# Payments (Stripe-compatible). Backend-only — never expose to clients.
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYMENT_SUCCESS_URL=https://takatak.ca/dashboard/orders?status=success
PAYMENT_CANCEL_URL=https://takatak.ca/dashboard/orders?status=cancelled

# Email (Resend). If EMAIL_PROVIDER=none, sends are logged only.
EMAIL_PROVIDER=none
RESEND_API_KEY=
EMAIL_FROM=TAKATAK <noreply@takatak.ca>
SUPPORT_EMAIL=support@takatak.ca
APP_BASE_URL=https://takatak.ca

# Stripe Connect (payout readiness). Leave disabled until Connect is approved.
PAYOUT_PROVIDER=none
PAYOUT_GRACE_PERIOD_HOURS=72
STRIPE_CONNECT_ENABLED=false
STRIPE_CONNECT_CLIENT_ID=
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_PLATFORM_FEE_PERCENT=10

# Portal launch URL signer
PORTAL_SIGNING_SECRET=replace-me
PORTAL_LAUNCH_TTL_SECONDS=120

# External portals (only set those that exist)
QMAPS_PORTAL_BASE_URL=
FLEXS_PORTAL_BASE_URL=
SOCIAL_PORTAL_BASE_URL=
VOIP_PORTAL_BASE_URL=
MARKETING_PORTAL_BASE_URL=
MARKETPLACE_PORTAL_BASE_URL=

# Lovable AI Gateway (server-side only, never exposed to clients)
LOVABLE_API_KEY=

# Service
PORT=10000
NODE_ENV=production
CORS_ORIGINS=https://takatak.ca,https://app.takatak.ca

# Monitoring (optional). Leave empty to disable Sentry.
SENTRY_DSN=

# Rate limiting (set to true to bypass — local/test only)
RATE_LIMIT_DISABLED=false

# Worker tuning
WORKER_POLL_MS=5000
WORKER_BATCH=5
WORKER_MAX_ATTEMPTS=5
WORKER_STUCK_MS=600000
ADMIN_NOTIFICATION_USER_ID=admin
