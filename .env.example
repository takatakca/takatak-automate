# ============================================================================
# TAKATAK ENVIRONMENT
# Three groups: (1) FRONTEND browser-safe vars, (2) FRONTEND server-only
# proxy vars, (3) BACKEND vars (see backend/.env.example for the full set).
# ============================================================================

# ---- (1) FRONTEND — browser-safe (VITE_*, bundled into the client) ----
# Anything here is visible to anyone who loads the site. Only put non-secret
# config like public widget URLs and optional portal fallback URLs.
VITE_API_BASE_URL=https://takatak.onrender.com

# Upmind widgets (loaded directly in the browser)
VITE_UPMIND_ORDER_CONFIG_URL=https://fimjpyw0mnzy.upmind.app/order/product
VITE_UPMIND_WIDGET_SCRIPT_URL=https://embed.upmind.app/upm-widget.js
VITE_UPMIND_DAC_SCRIPT_URL=https://widgets.upmind.app/dac/upm-dac.min.js
VITE_UPMIND_CURRENCY=CAD

# Optional public fallback portal URLs (used only if the backend launch
# endpoint is unreachable — signed URLs from the backend are preferred).
VITE_SOCIAL_PORTAL_URL=
VITE_VOIP_PORTAL_URL=
VITE_LEADS_PORTAL_URL=
VITE_LOCAL_LISTINGS_PORTAL_URL=
VITE_MARKETING_PORTAL_URL=
VITE_MARKETPLACE_PORTAL_URL=
VITE_QMAPS_PORTAL_URL=
VITE_FLEXS_PORTAL_URL=

# ---- (2) FRONTEND — server-only (TanStack proxy, NEVER prefix with VITE_) ----
# Read inside createServerFn handlers only. Not bundled into the browser.
# The frontend never calls the Render backend directly — every request goes
# through src/lib/render-proxy.functions.ts using this URL.
RENDER_API_BASE_URL=https://takatak.onrender.com

# Server-side portal URL fallbacks (only used by the proxy when backend
# /integrations/launch is not configured).
SOCIAL_PORTAL_URL=
VOIP_PORTAL_URL=
LEADS_PORTAL_URL=
LOCAL_LISTINGS_PORTAL_URL=
MARKETING_PORTAL_URL=
MARKETPLACE_PORTAL_URL=
QMAPS_PORTAL_URL=
FLEXS_PORTAL_URL=

# ---- (3) BACKEND (Render service) ----
# These belong in the Render dashboard, NOT here. Listed only as documentation.
# Full template: backend/.env.example
#   DATABASE_URL, AUTH_JWT_SECRET, UPMIND_WEBHOOK_SECRET,
#   AUTOMATION_WEBHOOK_SECRET, PORTAL_SIGNING_SECRET,
#   {QMAPS,FLEXS,SOCIAL,VOIP,MARKETING,MARKETPLACE}_PORTAL_BASE_URL,
#   LOVABLE_API_KEY, CORS_ORIGINS
